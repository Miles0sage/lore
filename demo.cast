[7.379691, "o", "\r\n  \u001b[0m  \u001b[2mCircuit Breaker Pattern — The Breaker, Guardian of the Gate\u001b[0m\u001b[0m\r\n  \u001b[0m  \u001b[2m\u001b[0m\u001b[0m\r\n  \u001b[0m  \u001b[2mPrevents cascading failures by monitoring request success rates and\u001b[0m\u001b[0m\r\n  \u001b[0m  \u001b[2minterrupting traffic to failing components. Three states: CLOSED (normal),\u001b[0m\u001b[0m\r\n  \u001b[0m  \u001b[2mOPEN (gate sealed), HALF_OPEN (single probe to test recovery).\u001b[0m\u001b[0m\r\n  \u001b[0m  \u001b[2m\u001b[0m\u001b[0m"]
[7.379699, "o", "\r\n"]
[7.379813, "o", "  \u001b[0m  \u001b[2mSystems without circuit breakers experience 76% failure rates in production.\u001b[0m\u001b[0m"]
[7.379821, "o", "\r\n  \u001b[0m  \u001b[2m\u001b[0m\u001b[0m\r\n  \u001b[0m  \u001b[2mUsage:\u001b[0m\u001b[0m\r\n  \u001b[0m  \u001b[2m    breaker = CircuitBreaker(name=\"openrouter_api\")\u001b[0m\u001b[0m\r\n  \u001b[0m  \u001b[2m    result = await breaker.call(my_api_function, arg1, arg2)\u001b[0m\u001b[0m\r\n  \u001b[0m  \u001b[2m\"\"\"\u001b[0m\u001b[0m\r\n  \u001b[0m  \u001b[2m\u001b[0m\u001b[0m\r\n  \u001b[0m  \u001b[2mimport asyncio\u001b[0m\u001b[0m"]
[7.379826, "o", "\r\n"]
